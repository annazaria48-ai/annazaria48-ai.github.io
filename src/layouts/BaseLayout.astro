---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig, absoluteUrl } from '../site';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  /** Подпись к превью в соцсетях (доступность и релевантность в выдаче) */
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  /** Не индексировать (404 и служебные страницы) */
  noindex?: boolean;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  ogImage,
  ogImageAlt,
  ogType = 'website',
  noindex = false,
  articlePublishedTime,
  articleModifiedTime,
  jsonLd,
} = Astro.props;

const canonicalPath = Astro.url.pathname;
const canonical = Astro.site
  ? new URL(canonicalPath, Astro.site).href
  : Astro.url.href;
const ogUrl = ogImage ?? absoluteUrl('/favicon.svg');
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content={siteConfig.psychologistName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogUrl} />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    {articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">К основному содержанию</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
