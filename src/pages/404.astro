---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../site';

const base = import.meta.env.BASE_URL;
const title = `Страница не найдена | ${siteConfig.psychologistName}`;
const description = 'Запрошенная страница не существует.';
---

<BaseLayout title={title} description={description} noindex>
  <section class="section not-found">
    <div class="container container--narrow">
      <h1>Страница не найдена</h1>
      <p>Возможно, ссылка устарела или адрес набран с ошибкой.</p>
      <p>
        <a class="btn" href={base}>На главную</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    min-height: 40vh;
    display: flex;
    align-items: center;
  }

  .not-found .container {
    width: 100%;
  }
</style>
