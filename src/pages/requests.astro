---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { siteConfig } from '../site';
import { canonicalFromAstro, innerPageJsonLd } from '../lib/seo';

const title = `С чем работает психолог — тревога, травмы, отношения, рост личности | ${siteConfig.psychologistName}`;
const description =
  'Помогаю при тревоге, панических атаках, депрессии, проблемах в отношениях, низкой самооценке, эмоциональном выгорании и раскрытии творческого потенциала.';

const groups = [
  {
    id: 'emotions',
    eyebrow: 'Эмоции и состояния',
    title: 'Когда эмоционально трудно',
    lead: 'Тревога, усталость, пустота — когда тело и психика сигналят, что что-то идёт не так.',
    accent: 'warm',
    topics: [
      {
        id: 'anxiety',
        title: 'Тревога и панические атаки',
        lead: 'Вы живёте в постоянном напряжении. Голова не выключается — бесконечные «а что если», сценарии катастроф, ощущение, что вот-вот случится что-то плохое.',
        items: [
          'Панические атаки — внезапный страх, сердцебиение, нехватка воздуха',
          'Генерализованная тревога — фоновое беспокойство «обо всём»',
          'Навязчивые мысли, от которых невозможно отвлечься',
          'Трудности с засыпанием — мозг не выключается',
          'Избегание ситуаций, которые вызывают тревогу',
        ],
        how: 'Снижаем избегание и переучиваем реакцию страха через экспозицию, осваиваем техники регуляции нервной системы. Через терапию частей находим ту часть, которая тревожится, и выясняем, что она пытается защитить.',
      },
      {
        id: 'depression',
        title: 'Депрессия и потеря сил',
        lead: 'Ничего не хочется. Нет сил, нет радости, нет смысла. Или свинцовая тяжесть, от которой невозможно встать с кровати.',
        items: [
          'Потеря интереса к тому, что раньше радовало',
          'Постоянная усталость, даже после отдыха',
          'Ощущение бессмысленности',
          'Трудности с концентрацией',
          'Социальная изоляция — не хочется видеть людей',
        ],
        how: 'Работаем с убеждениями о себе и будущем, возвращаем поведенческую активность и восстанавливаем смысл. Арт-терапевтические техники помогают выразить то, для чего пока нет слов. При выраженной симптоматике рекомендую совместную работу с психиатром.',
      },
      {
        id: 'burnout',
        title: 'Выгорание и стресс',
        lead: 'Вы работаете на износ. Раздражительность, цинизм, ощущение, что вы «пустая батарейка».',
        items: [
          'Эмоциональное истощение',
          'Деперсонализация — вы как будто «не здесь»',
          'Потеря профессиональной мотивации',
          'Раздражительность и вспышки гнева',
          'Бессонница, головные боли, снижение иммунитета',
        ],
        how: 'Выясняем, какие внутренние части «гонят» вас вперёд и почему они не дают остановиться. Работаем с перфекционизмом, границами и потребностями — иногда через арт-терапию, чтобы восстановить контакт с телом и ощущением себя.',
      },
      {
        id: 'trauma',
        title: 'Травмы и болезненный опыт прошлого',
        lead: 'То, что произошло давно, продолжает влиять на вас сейчас. Вы можете не думать об этом каждый день — но замечаете, что реагируете «не по ситуации».',
        items: [
          'Детские травмы — эмоциональное пренебрежение, жёсткое воспитание',
          'Травматические события — аварии, потери, насилие',
          'Посттравматический стресс — навязчивые воспоминания, кошмары',
          'Трудности с доверием и близостью',
          'Ощущение «замороженности» — как будто жизнь проходит мимо',
        ],
        how: 'Работаем через стабилизацию: EMDR, соматические техники, арт-терапию — образ или рисунок часто говорит о травме раньше, чем слова. Терапия частей помогает услышать те стороны себя, которые застряли в прошлом, и дать им поддержку. Темп определяете вы.',
      },
    ],
  },
  {
    id: 'relations',
    eyebrow: 'Отношения и личность',
    title: 'Когда сложно с собой и другими',
    lead: 'Повторяющиеся сценарии, внутренний критик, страх близости — паттерны, которые мешают жить.',
    accent: 'purple',
    topics: [
      {
        id: 'relations',
        title: 'Сложности в отношениях',
        lead: 'Вы замечаете, что одни и те же сценарии повторяются. Притягиваете «не тех» людей, теряете себя в отношениях, боитесь близости.',
        items: [
          'Созависимость — вы забываете о себе ради партнёра',
          'Страх близости — убегаете, когда отношения становятся серьёзными',
          'Повторяющиеся сценарии — одни и те же проблемы с разными людьми',
          'Сложности с границами — не можете сказать «нет»',
          'Ревность, контроль, недоверие',
        ],
        how: 'Исследуем стиль привязанности и схемы, которые управляют поведением в отношениях. Через терапию частей находим внутренние голоса, которые боятся близости или требуют раствориться в другом, — и учимся выстраивать связь иначе.',
      },
      {
        id: 'parents',
        title: 'Отношения с родителями',
        lead: 'Родители давно выросли, но их голос до сих пор живёт внутри. Вы замечаете, как их слова, ожидания или поступки продолжают управлять вашей жизнью — даже когда вы далеко.',
        items: [
          'Незавершённая сепарация — трудно принимать решения без оглядки на родителей',
          'Эмоциональное пренебрежение в детстве — вас не видели, не слышали, не поддерживали',
          'Давление ожиданий — «живи правильно», «будь таким, каким я хочу тебя видеть»',
          'Чувство вины — невозможно отстоять себя, не ощущая себя «плохим ребёнком»',
          'Нарциссическая или контролирующая родительская фигура',
          'Желание выстроить зрелые отношения с родителями — или принять, что это невозможно',
        ],
        how: 'Через терапию частей находим внутреннего «послушного ребёнка» и ту часть, которая несёт родительские голоса, — и начинаем разделять: где заканчиваются они и начинаетесь вы. Схема-терапия помогает переработать детские паттерны, а EMDR — освободить болезненные воспоминания. Арт-терапия мягко открывает то, что слишком больно для прямого разговора.',
      },
      {
        id: 'selfesteem',
        title: 'Самооценка и внутренний критик',
        lead: 'Голос внутри говорит: «ты недостаточно хорош», «ты не заслуживаешь». Вы сравниваете себя с другими и боитесь ошибиться.',
        items: [
          'Синдром самозванца — ощущение, что вас «разоблачат»',
          'Перфекционизм — невозможность начать, пока не будет «идеально»',
          'Постоянное сравнение себя с другими',
          'Страх критики и осуждения',
          'Невозможность принять комплимент',
        ],
        how: 'В терапии частей внутренний критик — это часть, которая когда-то взяла на себя защитную роль. Находим её, понимаем намерение и переводим из режима атаки в режим поддержки. Арт-терапия помогает увидеть и переосмыслить образ себя — буквально.',
      },
    ],
  },
  {
    id: 'growth',
    eyebrow: 'Рост и развитие',
    title: 'Когда хочется большего',
    lead: 'Иногда в терапию приходят не с болью, а с желанием раскрыть потенциал своей личности и больше проявляться в жизни.',
    accent: 'green',
    topics: [
      {
        id: 'growth',
        title: 'Раскрытие творческого потенциала',
        lead: 'Иногда в терапию приходят не с болью — а с желанием стать больше собой. Открыть то, что было заперто, разрешить себе то, о чём давно мечтали.',
        items: [
          'Ощущение, что внутри есть что-то нереализованное — но не ясно, что именно',
          'Творческий блок: хочется создавать, но что-то останавливает',
          'Страх выражать себя — быть замеченным, осуждённым, «слишком»',
          'Желание развиваться, но непонимание — в какую сторону',
          'Жизнь формально устроена, но ощущение, что она «не ваша»',
          'Поиск своего голоса — в профессии, творчестве, отношениях',
        ],
        how: 'Арт-терапия здесь особенно точна: творческий процесс в безопасном пространстве сам по себе ослабляет внутренние запреты. Через терапию частей находим ту сторону себя, которая хочет творить, — и ту, которая запрещает, — и выстраиваем между ними диалог.',
      },
      {
        id: 'career',
        title: 'Карьерные консультации',
        lead: 'Вы работаете — но не понимаете, туда ли идёте. Или стоите на месте и не можете сдвинуться.',
        items: [
          '«Я не знаю, чем хочу заниматься» — профессия есть, но она не ваша',
          'Страх сменить сферу — кажется, что уже поздно',
          'Ступор при выборе между несколькими направлениями',
          'Ощущение, что вы «не на своём месте»',
          'Демотивация от работы, которая когда-то нравилась',
        ],
        how: 'Разбираемся, что стоит за ступором: тревога, чужие сценарии или конфликт между частями — одна хочет перемен, другая боится потерять стабильность. Прояснение ценностей и сильных сторон помогает двигаться из осознанности, а не из страха.',
      },
    ],
  },
];

const canonical = canonicalFromAstro(Astro.site, Astro.url);
const jsonLd = innerPageJsonLd({ canonical, title, description });
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="page-hero section">
    <div class="container">
      <h1>С чем я могу вам помочь</h1>
      <p class="page-hero__lead">
        Не нужно точно знать, что именно вас беспокоит. Иногда достаточно ощущения «что-то не так» — или, напротив, желания стать больше собой. Разобраться в этом вместе и есть наша работа.
      </p>
      <nav class="group-nav" aria-label="Разделы">
        {groups.map(g => (
          <a href={`#group-${g.id}`} class="group-nav__link">{g.eyebrow}</a>
        ))}
      </nav>
    </div>
  </section>

  {groups.map((group, gi) => (
    <section
      id={`group-${group.id}`}
      class:list={['group-section section', gi === 0 ? 'group-section--first' : '', gi % 2 === 1 ? 'section--alt' : '']}
      aria-labelledby={`group-heading-${group.id}`}
    >
      <div class="container">
        <div class="group-header">
          <span class:list={['eyebrow', `eyebrow--${group.accent}`]}>{group.eyebrow}</span>
          <h2 id={`group-heading-${group.id}`} class="group-header__title">{group.title}</h2>
          <p class="group-header__lead">{group.lead}</p>
        </div>

        <div class="zigzag">
          {group.topics.map((topic, ti) => (
            <div class:list={['zitem', ti % 2 === 1 ? 'zitem--reverse' : '']} id={topic.id}>
              <div class="zitem__accent">
                <div class:list={['zitem__accent-inner', `zitem__accent-inner--${group.accent}`]}>
                  <span class="zitem__num">0{ti + 1}</span>
                </div>
              </div>
              <div class="zitem__content">
                <h3 class="zitem__title">{topic.title}</h3>
                <p class="zitem__lead">{topic.lead}</p>
                <ul class="zitem__list">
                  {topic.items.map(item => <li>{item}</li>)}
                </ul>
                <div class="zitem__how">
                  <span class="zitem__how-label">Как работаю с этим</span>
                  <p>{topic.how}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="section section--alt">
    <div class="container">
      <div class="requests-cta">
        <h2>Не нашли свою проблему?</h2>
        <p>Если вашей темы здесь нет, запишитесь на пробную консультацию: на ней мы вместе разберёмся, что для вас важно, и поймём, смогу ли я помочь именно с вашей ситуацией.</p>
        <CTA label="Записаться на пробную консультацию" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────── */
  .page-hero {
    padding-top: calc(var(--space-xl) / 2);
    padding-bottom: var(--space-lg);
  }

  .page-hero__lead {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  /* ── Group nav ─────────────────────────────────── */
  .group-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-sm);
  }

  .group-nav__link {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .group-nav__link:hover {
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  /* ── Group header ──────────────────────────────── */
  .group-section,
  .zitem {
    scroll-margin-top: 4rem;
  }

  .group-section--first {
    padding-top: 1.5rem;
  }

  .group-header {
    margin-bottom: var(--space-xl);
  }

  .group-header__title {
    margin-top: 0.3rem;
    margin-bottom: 0.5rem;
  }

  .group-header__lead {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin: 0;
  }

  /* Eyebrow accent variants */
  .eyebrow--warm { color: var(--color-accent-warm); }
  .eyebrow--purple { color: var(--color-accent); }
  .eyebrow--green { color: #3a7a5e; }

  /* ── Zigzag ────────────────────────────────────── */
  .zigzag {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .zitem {
    display: grid;
    gap: var(--space-lg);
    align-items: start;
  }

  @media (min-width: 768px) {
    .zitem {
      grid-template-columns: 220px 1fr;
    }

    .zitem--reverse {
      grid-template-columns: 1fr 220px;
    }

    .zitem--reverse .zitem__accent {
      order: 2;
    }

    .zitem--reverse .zitem__content {
      order: 1;
    }
  }

  /* Accent column */
  .zitem__accent {
    display: flex;
    justify-content: center;
  }

  .zitem__accent-inner {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .zitem__accent-inner--warm {
    background: rgba(200, 128, 90, 0.12);
    border: 1px solid rgba(200, 128, 90, 0.25);
  }

  .zitem__accent-inner--purple {
    background: var(--color-accent-light);
    border: 1px solid rgba(74, 48, 96, 0.2);
  }

  .zitem__accent-inner--green {
    background: rgba(58, 122, 94, 0.1);
    border: 1px solid rgba(58, 122, 94, 0.2);
  }

  .zitem__num {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-border);
  }

  /* Content column */
  .zitem__title {
    margin: 0 0 0.6rem;
    font-size: 1.25rem;
    color: var(--color-text);
  }

  .zitem__lead {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-bottom: var(--space-sm);
    line-height: 1.6;
  }

  .zitem__list {
    margin: 0 0 var(--space-sm);
    padding-left: 1.1rem;
  }

  .zitem__list li {
    font-size: 0.925rem;
    color: var(--color-text-muted);
    margin-bottom: 0.35rem;
    line-height: 1.5;
  }

  .zitem__how {
    background: var(--color-bg-alt);
    border-radius: var(--radius);
    padding: 0.9rem 1.1rem;
    border-left: 3px solid var(--color-accent);
    margin-top: var(--space-sm);
  }

  .zitem__how-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.35rem;
  }

  .zitem__how p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  /* ── Final CTA ─────────────────────────────────── */
  .requests-cta {
    max-width: 560px;
    margin-inline: auto;
    text-align: center;
    padding: var(--space-lg) 0 var(--space-sm);
  }

  .requests-cta h2 {
    margin-top: 0;
  }
</style>
