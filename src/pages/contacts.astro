---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingSection from '../components/BookingSection.astro';
import { siteConfig } from '../site';
import { canonicalFromAstro, innerPageJsonLd } from '../lib/seo';

const title = `Связаться с психологом | ${siteConfig.psychologistName}`;
const description = `Оставьте контакты в форме — психолог ${siteConfig.psychologistName} свяжется с вами в течение 24 часов. ${siteConfig.city}. Онлайн и очно.`;

const baseUrl = import.meta.env.BASE_URL;
const homeHref = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;

const canonical = canonicalFromAstro(Astro.site, Astro.url);
const jsonLd = innerPageJsonLd({ canonical, title, description });
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="page-hero section page-hero--contacts">
    <div class="container">
      <div class="page-hero__back-row">
        <button type="button" id="contacts-back" class="contacts-back contacts-back--hero">← Назад</button>
      </div>
      <h1>Вы уже сделали шаг</h1>
      <p class="page-hero__lead">
        То, что вы здесь — уже важно. Вам не нужно заранее придумывать «правильный» запрос или красиво собирать мысли в текст: достаточно выбрать любой из способов связи и после записи прийти на консультацию. Будем разбираться вместе.
      </p>
    </div>
  </section>

  <BookingSection compactTop heading="Оставьте контакт, и я свяжусь с вами" />

  <section class="contacts-section section section--alt contacts-section--after-form" aria-labelledby="contacts-heading">
    <div class="container">
      <div class="contacts-grid">
        <!-- Мессенджеры -->
        <div class="contacts-main">
          <h2 id="contacts-heading">Свяжитесь со мной</h2>
          <div class="contact-cards">
            <a
              href={siteConfig.telegramUrl}
              class="ccard"
              target="_blank"
              rel="noopener"
              aria-label={`Telegram: ${siteConfig.telegramDisplay}`}
            >
              <div class="ccard__icon ccard__icon--tg" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.248l-2.026 9.548c-.148.665-.54.827-1.093.514l-3.01-2.217-1.452 1.396c-.16.16-.295.295-.605.295l.215-3.053 5.557-5.017c.242-.215-.052-.334-.373-.12L6.4 14.61l-2.94-.918c-.64-.2-.652-.64.133-.948l11.483-4.428c.533-.193 1.001.13.486 1.933z"/></svg>
              </div>
              <div class="ccard__text">
                <p class="ccard__label">Telegram</p>
                <p class="ccard__value">{siteConfig.telegramDisplay}</p>
              </div>
              <div class="ccard__arrow" aria-hidden="true">→</div>
            </a>

            <a
              href={siteConfig.whatsappUrl}
              class="ccard"
              target="_blank"
              rel="noopener"
              aria-label={`WhatsApp: ${siteConfig.whatsappCardLabel}`}
            >
              <div class="ccard__icon ccard__icon--wa" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <div class="ccard__text">
                <p class="ccard__label">WhatsApp</p>
                <p class="ccard__value">{siteConfig.whatsappCardLabel}</p>
              </div>
              <div class="ccard__arrow" aria-hidden="true">→</div>
            </a>

            <a href={`mailto:${siteConfig.email}`} class="ccard">
              <div class="ccard__icon ccard__icon--email" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div class="ccard__text">
                <p class="ccard__label">Email</p>
                <p class="ccard__value">{siteConfig.email}</p>
              </div>
              <div class="ccard__arrow" aria-hidden="true">→</div>
            </a>
          </div>

          <div class="side-block contacts-office">
            <h2>Очный приём</h2>
            <p class="side-text"><strong>Город:</strong> {siteConfig.city}</p>
            <p class="side-text"><strong>Метро:</strong> ст. «Чернышевская»</p>
            <div class="office-placeholder" role="img" aria-label="Фото кабинета">
              <span>Фото кабинета</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ homeHref }}>
  document.getElementById('contacts-back')?.addEventListener('click', () => {
    if (window.history.length > 1) {
      window.history.back();
    } else {
      window.location.href = homeHref;
    }
  });
</script>

<style>
  .page-hero {
    padding-bottom: var(--space-lg);
  }

  /* Сразу под шапкой: меньше верхний отступ; кнопка строкой над «Контакты», не рядом */
  .page-hero--contacts.section {
    padding-top: calc(var(--space-xl) / 2);
  }

  .page-hero__back-row {
    display: block;
    margin-bottom: var(--space-sm);
  }

  .page-hero--contacts .contacts-back--hero {
    display: inline-flex;
    margin: 0;
  }

  .page-hero__lead {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-top: var(--space-sm);
  }

  .contacts-section--after-form {
    padding-top: calc(var(--space-xl) * 0.3);
  }

  .contacts-grid {
    display: grid;
    gap: var(--space-xl);
  }

  /* Contact cards */
  .contacts-back {
    display: inline-flex;
    align-items: center;
    margin: 0;
    padding: 0.35rem 0.5rem 0.35rem 0;
    border: none;
    background: none;
    font: inherit;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    cursor: pointer;
    border-radius: var(--radius);
    transition: color 0.15s, background 0.15s;
  }

  .contacts-back:hover {
    color: var(--color-accent);
    background: var(--color-bg-alt);
  }

  .contacts-back:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .contacts-main h2 {
    margin-top: 0;
  }

  #contacts-heading {
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
  }

  .contact-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 0;
  }

  .contacts-main .contacts-office {
    margin-top: var(--space-xl);
  }

  .ccard {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 1rem 1.25rem;
    background: var(--color-surface-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
  }

  .ccard:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px rgba(92, 61, 122,0.1);
    transform: translateY(-1px);
    color: var(--color-text);
    text-decoration: none;
  }

  .ccard__icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ccard__icon--tg { background: rgba(39,159,236,0.12); color: #229ED9; }
  .ccard__icon--wa { background: rgba(37,211,102,0.12); color: #25D366; }
  .ccard__icon--email { background: var(--color-accent-light); color: var(--color-accent); }

  .ccard__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .ccard__label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .ccard__value {
    font-weight: 500;
    font-size: 0.95rem;
    margin: 0;
  }

  .ccard__arrow {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    transition: transform 0.2s;
  }

  .ccard:hover .ccard__arrow {
    transform: translateX(3px);
    color: var(--color-accent);
  }

  .side-block h2 {
    font-size: 1.15rem;
    margin-top: 0;
    margin-bottom: var(--space-sm);
  }

  /* Как у заголовков формы и «Свяжитесь со мной» (.booking-section h2, #contacts-heading) */
  .contacts-main .contacts-office h2 {
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
  }

  .side-text {
    font-size: 0.9rem;
    margin-bottom: 0.4rem;
    color: var(--color-text-muted);
  }

  .side-text:last-of-type {
    margin-bottom: var(--space-sm);
  }

  .office-placeholder {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
</style>
