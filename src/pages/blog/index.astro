---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { BlogTopic } from '../../content/config';
import { siteConfig } from '../../site';
import { blogIndexJsonLd, canonicalFromAstro } from '../../lib/seo';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const title = `Блог | ${siteConfig.psychologistName}`;
const description =
  'Статьи о тревоге, гипнотерапии, IFS, арт-терапии и самооценке. Полезные материалы от психолога.';

const canonical = canonicalFromAstro(Astro.site, Astro.url);
const jsonLd = blogIndexJsonLd({ canonical, title, description });

const TOPIC_LABELS: Record<BlogTopic, string> = {
  anxiety: 'Тревога',
  depression: 'Депрессия',
  burnout: 'Выгорание',
  trauma: 'Травмы',
  relations: 'Отношения',
  family: 'Родители и семья',
  'self-esteem': 'Самооценка',
  growth: 'Рост и творчество',
  career: 'Карьера',
  hypnotherapy: 'Гипнотерапия',
  ifs: 'IFS',
  'art-therapy': 'Арт-терапия',
};

const TOPIC_ORDER: BlogTopic[] = [
  'anxiety',
  'depression',
  'burnout',
  'trauma',
  'relations',
  'family',
  'self-esteem',
  'growth',
  'career',
  'hypnotherapy',
  'ifs',
  'art-therapy',
];

const usedTopics = new Set<BlogTopic>();
for (const p of posts) {
  for (const t of p.data.topics ?? []) usedTopics.add(t);
}

const topicChips = TOPIC_ORDER.filter((slug) => usedTopics.has(slug)).map((slug) => ({
  id: slug,
  label: TOPIC_LABELS[slug],
  match: [slug],
}));

const blogFilters: { id: string; label: string; match: string[] }[] = [
  { id: 'all', label: 'Все', match: [] },
  ...topicChips,
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="page-hero section">
    <div class="container">
      <h1>Статьи и материалы</h1>
      <nav class="blog-filter" aria-label="Фильтр по темам">
        {
          blogFilters.map((f, i) => (
            <button
              type="button"
              class:list={['blog-filter__btn', i === 0 && 'blog-filter__btn--active']}
              data-blog-filter={f.id}
              data-match={f.match.join(',')}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              {f.label}
            </button>
          ))
        }
      </nav>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <p id="blog-filter-empty" class="blog-filter__empty" hidden>
        Пока нет материалов в этой рубрике — загляните в другой раздел или ко всем статьям.
      </p>
      <ul class="post-list" id="post-list">
        {posts.map((post) => (
          <li data-topics={(post.data.topics ?? []).join(',')}>
            <article class="post-card">
              <div class="post-card__meta">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('ru-RU', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
              </div>
              <h2 class="post-card__title">
                <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`}>{post.data.title}</a>
              </h2>
              <p class="post-card__desc">{post.data.description}</p>
              <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="post-card__link">Читать статью →</a>
            </article>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<script>
  (function () {
    const list = document.getElementById('post-list');
    const empty = document.getElementById('blog-filter-empty');
    const buttons = document.querySelectorAll('[data-blog-filter]');
    if (!list) return;

    function parseTopics(li) {
      const raw = li.getAttribute('data-topics') || '';
      return raw.split(',').filter(Boolean);
    }

    function applyFilter(matchIds) {
      const matchSet = new Set(matchIds);
      const showAll = matchSet.size === 0;
      const items = list.querySelectorAll('li[data-topics]');
      let n = 0;
      items.forEach((li) => {
        const topics = parseTopics(li);
        const show = showAll || topics.some((t) => matchSet.has(t));
        li.hidden = !show;
        if (show) n += 1;
      });
      if (empty) empty.hidden = n > 0;
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => {
          const on = b === btn;
          b.classList.toggle('blog-filter__btn--active', on);
          b.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
        const raw = btn.getAttribute('data-match') || '';
        const ids = raw
          .split(',')
          .map((s) => s.trim())
          .filter(Boolean);
        applyFilter(ids);
      });
    });
  })();
</script>

<style>
  .page-hero {
    padding-bottom: var(--space-lg);
  }

  .page-hero.section {
    padding-top: calc(var(--space-xl) / 2);
  }

  .blog-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-md);
    max-width: 52rem;
  }

  .blog-filter__btn {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    cursor: pointer;
    transition:
      background 0.15s,
      border-color 0.15s,
      color 0.15s;
  }

  .blog-filter__btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .blog-filter__btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .blog-filter__btn--active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .blog-filter__btn--active:hover {
    color: #fff;
    border-color: var(--color-accent-hover);
    background: var(--color-accent-hover);
  }

  .blog-filter__empty {
    margin: 0 0 var(--space-md);
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .post-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .post-list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .post-list li {
    display: flex;
  }

  .post-list li[hidden] {
    display: none;
  }

  .post-card {
    background: var(--color-surface-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    transition: box-shadow 0.2s, transform 0.15s;
  }

  .post-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .post-card__meta time {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .post-card__title {
    font-size: 1.1rem;
    margin: 0;
    line-height: 1.3;
  }

  .post-card__title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-card__title a:hover {
    color: var(--color-accent);
  }

  .post-card__desc {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    flex: 1;
  }

  .post-card__link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: 0.25rem;
  }

  .post-card__link:hover {
    text-decoration: underline;
  }
</style>
