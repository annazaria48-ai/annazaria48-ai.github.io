---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import { siteConfig } from '../../site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const title = `${post.data.title} | ${siteConfig.psychologistName}`;
const description = post.data.description;
---

<BaseLayout title={title} description={description}>
  <article class="section article">
    <div class="container container--narrow prose">
      <header class="article__header">
        <h1>{post.data.title}</h1>
        <time class="article__date" datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('ru-RU', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        {post.data.tags && post.data.tags.length > 0 && (
          <p class="article__tags">
            {post.data.tags.map((t) => (
              <span class="tag">{t}</span>
            ))}
          </p>
        )}
      </header>
      <div class="article__body">
        <Content />
      </div>
      <footer class="article__footer">
        <CTA label="Записаться на консультацию" />
        <p>
          <a href={`${import.meta.env.BASE_URL}blog`}>← Все статьи блога</a>
        </p>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .article__header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .article__date {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .article__tags {
    margin: var(--space-sm) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-size: 0.8rem;
    background: var(--color-bg-alt);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    color: var(--color-text-muted);
  }

  .article__body :global(h2) {
    margin-top: var(--space-lg);
  }

  .article__footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }
</style>
