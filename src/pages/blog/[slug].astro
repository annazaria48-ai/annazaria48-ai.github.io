---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import { siteConfig } from '../../site';
import { blogPostJsonLd, canonicalFromAstro } from '../../lib/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const title = `${post.data.title} | ${siteConfig.psychologistName}`;
const description = post.data.description;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const canonical = canonicalFromAstro(Astro.site, Astro.url);
const dateIso = post.data.date.toISOString();
const jsonLd = blogPostJsonLd({
  canonical,
  headline: post.data.title,
  description,
  datePublished: dateIso,
  dateModified: dateIso,
  slug: post.slug,
});
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  articlePublishedTime={dateIso}
  articleModifiedTime={dateIso}
  jsonLd={jsonLd}
>
  <section class="article-hero section">
    <div class="container container--narrow">
      <a href={`${import.meta.env.BASE_URL}blog`} class="back-link">← Все статьи</a>
      <div class="article-meta">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('ru-RU', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="article-tags">
            {post.data.tags.map((t) => (
              <span class="tag">{t}</span>
            ))}
          </div>
        )}
      </div>
      <h1>{post.data.title}</h1>
    </div>
  </section>

  <article class="section section--alt">
    <div class="container container--narrow">
      <div class="article-body prose">
        <Content />
      </div>
      <footer class="article-footer">
        <h3>Эта тема откликается? Давайте поговорим</h3>
        <CTA label="Записаться на пробную консультацию" />
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .article-hero {
    padding-bottom: var(--space-md);
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-md);
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: var(--space-sm);
  }

  .article-meta time {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .article-body :global(h2) {
    margin-top: var(--space-lg);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
  }

  .article-body :global(h3) {
    margin-top: var(--space-md);
  }

  .article-body :global(img) {
    border-radius: var(--radius);
    margin: var(--space-md) 0;
  }

  .article-footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
    background: var(--color-surface-white);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  .article-footer h3 {
    margin-top: 0;
    font-size: 1.2rem;
  }

  .article-footer p {
    color: var(--color-text-muted);
    margin-bottom: 0;
  }
</style>
