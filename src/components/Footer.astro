---
import { siteConfig } from '../site';

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="site-footer">
  <div class="footer-top">
    <div class="container footer-top__inner">
      <div class="footer-brand">
        <p class="footer-name">{siteConfig.psychologistName}</p>
        <p class="footer-tagline">Психолог-консультант · {siteConfig.city}</p>
      </div>
      <div class="footer-links">
        <nav aria-label="Навигация в подвале">
          <ul>
            <li><a href={`${base}/`}>Обо мне</a></li>
            <li><a href={`${base}/requests`}>С чем работаю</a></li>
            <li><a href={`${base}/process`}>Как проходит</a></li>
            <li><a href={`${base}/pricing`}>Стоимость</a></li>
            <li><a href={`${base}/blog`}>Блог</a></li>
          </ul>
        </nav>
      </div>
      <div class="footer-contact">
        <p class="footer-contact__label">Связаться</p>
        <a href={`${base}/contacts`} class="footer-contact__link">Контакты и запись</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container footer-bottom__inner">
      <p>&copy; {year} {siteConfig.psychologistName}</p>
      <p>Онлайн и очно · {siteConfig.city}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-dark);
    color: rgba(250, 249, 246, 0.7);
    margin-top: 0;
  }

  .footer-top {
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .footer-top__inner {
    display: grid;
    gap: var(--space-lg);
  }

  @media (min-width: 768px) {
    .footer-top__inner {
      grid-template-columns: 1.5fr 1fr 1fr;
      align-items: start;
    }
  }

  .footer-name {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 600;
    color: #faf9f6;
    margin: 0 0 0.3rem;
    line-height: 1.2;
  }

  .footer-tagline {
    font-size: 0.875rem;
    margin: 0;
    color: rgba(250, 249, 246, 0.5);
  }

  .footer-links ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-links a {
    color: rgba(250, 249, 246, 0.6);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: #faf9f6;
  }

  .footer-contact__label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(250, 249, 246, 0.4);
    margin: 0 0 0.75rem;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-contact__link {
    color: rgba(250, 249, 246, 0.6);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-contact__link:hover {
    color: var(--color-accent);
  }

  .footer-bottom {
    border-top: 1px solid rgba(250, 249, 246, 0.08);
    padding: var(--space-md) 0;
  }

  .footer-bottom__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-xs);
  }

  .footer-bottom p {
    margin: 0;
    font-size: 0.8rem;
    color: rgba(250, 249, 246, 0.3);
  }
</style>
