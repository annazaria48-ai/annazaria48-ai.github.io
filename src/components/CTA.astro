---
interface Props {
  label?: string;
  class?: string;
  variant?: 'default' | 'dark' | 'outline';
}

const { label = 'Записаться на пробную консультацию', class: className = '', variant = 'default' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const btnClass = variant === 'dark' ? 'btn btn--dark' : variant === 'outline' ? 'btn btn--outline' : 'btn';
---

<div class:list={['cta-block', className]}>
  <a class={btnClass} href={`${base}/contacts`}>{label}</a>
</div>

<style>
  .cta-block {
    margin: var(--space-md) 0;
  }
</style>
