---
import { siteConfig } from '../site';

const base = import.meta.env.BASE_URL;
const nav = [
  { href: `${base}`, label: 'Главная' },
  { href: `${base}about`, label: 'Обо мне' },
  { href: `${base}requests`, label: 'С чем я работаю' },
  { href: `${base}process`, label: 'Как проходит терапия' },
  { href: `${base}pricing`, label: 'Стоимость' },
  { href: `${base}blog`, label: 'Блог' },
  { href: `${base}contacts`, label: 'Контакты' },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href={base} class="site-header__brand">{siteConfig.psychologistName}</a>
    <button type="button" class="site-header__toggle" aria-expanded="false" aria-controls="site-nav" data-nav-toggle>
      <span class="visually-hidden">Меню</span>
      <span class="site-header__burger" aria-hidden="true"></span>
    </button>
    <nav id="site-nav" class="site-nav" data-nav>
      <ul class="site-nav__list">
        {nav.map((item) => (
          <li>
            <a href={item.href} class="site-nav__link">{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(246, 243, 238, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    padding: var(--space-sm) 0;
    max-width: var(--max-width-wide);
    width: min(100% - 2rem, var(--max-width-wide));
    margin-inline: auto;
  }

  .site-header__brand {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
  }

  .site-header__brand:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .site-header__toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
  }

  @media (min-width: 900px) {
    .site-header__toggle {
      display: none;
    }
  }

  .site-header__burger {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    position: relative;
  }

  .site-header__burger::before,
  .site-header__burger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 22px;
    height: 2px;
    background: var(--color-text);
  }

  .site-header__burger::before {
    top: -7px;
  }

  .site-header__burger::after {
    top: 7px;
  }

  .site-nav {
    display: none;
  }

  .site-nav.is-open {
    display: block;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-md);
    box-shadow: var(--shadow);
  }

  @media (min-width: 900px) {
    .site-nav {
      display: block;
      position: static;
      padding: 0;
      border: none;
      box-shadow: none;
      background: transparent;
    }
  }

  .site-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  @media (min-width: 900px) {
    .site-nav__list {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: var(--space-sm);
    }
  }

  .site-nav__link {
    display: block;
    padding: 0.35rem 0;
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .site-nav__link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
</style>

<script>
  const toggle = document.querySelector('[data-nav-toggle]');
  const nav = document.querySelector('[data-nav]');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const open = nav.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
</script>
