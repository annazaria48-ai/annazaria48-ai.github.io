---
import { siteConfig } from '../site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const nav = [
  { href: `${base}/requests`, label: 'С чем работаю' },
  { href: `${base}/process`, label: 'Как проходит' },
  { href: `${base}/pricing`, label: 'Стоимость' },
  { href: `${base}/blog`, label: 'Блог' },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={`${base}/`} class="site-header__brand">
      <span class="brand-first">{siteConfig.shortName}</span>
      <span class="brand-last">{siteConfig.psychologistName.split(' ')[1]}</span>
    </a>

    <button type="button" class="site-header__toggle" aria-expanded="false" aria-controls="site-nav" data-nav-toggle>
      <span class="visually-hidden">Меню</span>
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>

    <nav id="site-nav" class="site-nav" data-nav>
      <ul class="site-nav__list">
        {nav.map((item) => (
          <li>
            <a href={item.href} class="site-nav__link">{item.label}</a>
          </li>
        ))}
      </ul>
      <a href={`${base}/contacts`} class="btn btn-header">Записаться</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(244, 244, 244, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    padding: 0.9rem 1.5rem;
    max-width: var(--max-width-wide);
    margin-inline: auto;
  }

  /* Brand */
  .site-header__brand {
    display: flex;
    align-items: baseline;
    gap: 0.35em;
    text-decoration: none;
    line-height: 1;
  }

  .brand-first {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.15rem;
    color: var(--color-text);
    transition: color 0.2s;
  }

  .brand-last {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: normal;
    font-size: 1.15rem;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .site-header__brand:hover .brand-first,
  .site-header__brand:hover .brand-last {
    color: var(--color-accent);
  }

  /* Mobile toggle */
  .site-header__toggle {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
  }

  @media (min-width: 900px) {
    .site-header__toggle {
      display: none;
    }
  }

  .burger-line {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
  }

  .site-header__toggle[aria-expanded="true"] .burger-line:nth-child(1) {
    transform: translateY(3.75px) rotate(45deg);
  }

  .site-header__toggle[aria-expanded="true"] .burger-line:nth-child(2) {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  /* Nav */
  .site-nav {
    display: none;
  }

  .site-nav.is-open {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-md) 1.5rem;
    box-shadow: var(--shadow-md);
  }

  @media (min-width: 900px) {
    .site-nav {
      display: flex;
      align-items: center;
      gap: var(--space-md);
      position: static;
      padding: 0;
      border: none;
      box-shadow: none;
      background: transparent;
    }
  }

  .site-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  @media (min-width: 900px) {
    .site-nav__list {
      flex-direction: row;
      align-items: center;
      gap: 0.25rem;
    }
  }

  .site-nav__link {
    display: block;
    padding: 0.45rem 0.65rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.925rem;
    font-weight: 400;
    border-radius: var(--radius-pill);
    transition: color 0.2s, background 0.2s;
  }

  .site-nav__link:hover {
    color: var(--color-text);
    background: var(--color-bg-alt);
    text-decoration: none;
  }

  /* CTA in header */
  .btn-header {
    padding: 0.55rem 1.2rem;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
</style>

<script>
  const toggle = document.querySelector('[data-nav-toggle]');
  const nav = document.querySelector('[data-nav]');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const open = nav.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
</script>
